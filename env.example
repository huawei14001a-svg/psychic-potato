  const childCount = db.prepare('SELECT COUNT(*) AS c FROM children WHERE marriage_id=?').get(marriage.id).c;
  const pregnancy  = db.prepare("SELECT id FROM pregnancies WHERE marriage_id=? AND status='ongoing'").get(marriage.id);

  let msg = `👨‍👩‍👦 Семья\n\n👶 Детей: ${childCount}`;
  if (pregnancy) msg += `\n🤰 Ожидаете пополнения!`;
  msg += `\n🎲 Шанс ребёнка: ${chance}%`;
  if (days < 180) msg += `\n⏳ До возможности: ${180 - days} дней`;

  await ctx.reply(msg, {
    reply_markup: { inline_keyboard: [[{ text: '📱 Подробнее', web_app: { url: `${WEBAPP_URL}?user_id=${ctx.from.id}` } }]] }
  });
});

bot.action('quick_divorce', async (ctx) => {
  await ctx.answerCbQuery();
  const marriage = getActiveMarriage(ctx.from.id);
  if (!marriage) return ctx.reply('❌ Вы не в браке');
