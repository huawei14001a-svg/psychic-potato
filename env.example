// ╔══════════════════════════════════════════════════════════════╗
// ║          VERIFURE — Медвежьи отношения и браки              ║
// ║              Telegram Bot + Mini App Server                  ║
// ╚══════════════════════════════════════════════════════════════╝
require('dotenv').config();

const { Telegraf, Markup } = require('telegraf');
const express = require('express');
const Database = require('better-sqlite3');
const path = require('path');

// ══════════════════════════════════════════
// КОНФИГУРАЦИЯ
// ══════════════════════════════════════════
const BOT_TOKEN = process.env.BOT_TOKEN;
const PORT = parseInt(process.env.PORT) || 3000;
const WEBAPP_URL = (process.env.WEBAPP_URL || '').replace(/\/$/, '') || `http://localhost:${PORT}`;

if (!BOT_TOKEN) {
  console.error('❌ BOT_TOKEN не задан! Проверьте .env или переменные Railway.');
  process.exit(1);
}

console.log(`🔧 PORT=${PORT} | WEBAPP_URL=${WEBAPP_URL}`);

// ══════════════════════════════════════════
// БАЗА ДАННЫХ
// ══════════════════════════════════════════
const db = new Database(process.env.DB_PATH || './verifure.db');
db.pragma('journal_mode = WAL');
db.pragma('foreign_keys = ON');
db.pragma('busy_timeout = 5000');

db.exec(`
  CREATE TABLE IF NOT EXISTS users (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    telegram_id     INTEGER UNIQUE NOT NULL,
    username        TEXT,
    first_name      TEXT NOT NULL DEFAULT 'User',
    last_name       TEXT,
    last_active     DATETIME DEFAULT CURRENT_TIMESTAMP,
    created_at      DATETIME DEFAULT CURRENT_TIMESTAMP
  );

  CREATE TABLE IF NOT EXISTS proposals (
    id                  INTEGER PRIMARY KEY AUTOINCREMENT,
    from_telegram_id    INTEGER NOT NULL,
    to_telegram_id      INTEGER NOT NULL,
    to_username         TEXT,
    status              TEXT DEFAULT 'pending',
    created_at          DATETIME DEFAULT CURRENT_TIMESTAMP
  );

  CREATE TABLE IF NOT EXISTS marriages (
    id                  INTEGER PRIMARY KEY AUTOINCREMENT,
    user1_telegram_id   INTEGER NOT NULL,
    user2_telegram_id   INTEGER NOT NULL,
    status              TEXT DEFAULT 'active',
    created_at          DATETIME DEFAULT CURRENT_TIMESTAMP,
    divorce_started_at  DATETIME,
    divorce_initiator   INTEGER
  );

  CREATE TABLE IF NOT EXISTS activity_logs (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    telegram_id     INTEGER NOT NULL,
    marriage_id     INTEGER NOT NULL,
    log_date        TEXT NOT NULL,
    message_count   INTEGER DEFAULT 0,
    UNIQUE(telegram_id, marriage_id, log_date)
  );

  CREATE TABLE IF NOT EXISTS pregnancies (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    marriage_id     INTEGER NOT NULL,
    started_at      DATETIME DEFAULT CURRENT_TIMESTAMP,
    status          TEXT DEFAULT 'ongoing',
    born_at         DATETIME
  );

  CREATE TABLE IF NOT EXISTS children (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    marriage_id     INTEGER NOT NULL,
    born_at         DATETIME DEFAULT CURRENT_TIMESTAMP,
    birth_number    INTEGER DEFAULT 1
  );

  CREATE TABLE IF NOT EXISTS notifications (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    telegram_id     INTEGER NOT NULL,
    marriage_id     INTEGER,
    type            TEXT NOT NULL,
    sent_at         DATETIME DEFAULT CURRENT_TIMESTAMP
  );
`);

// ══════════════════════════════════════════
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ БД
// ══════════════════════════════════════════

function upsertUser(from) {
  try {
    db.prepare(`
      INSERT INTO users (telegram_id, username, first_name, last_name)
      VALUES (?, ?, ?, ?)
      ON CONFLICT(telegram_id) DO UPDATE SET
        username   = excluded.username,
        first_name = excluded.first_name,
        last_name  = excluded.last_name,
        last_active = CURRENT_TIMESTAMP
    `).run(from.id, from.username || null, from.first_name || 'User', from.last_name || null);
    return db.prepare('SELECT * FROM users WHERE telegram_id = ?').get(from.id);
  } catch(e) {
    console.error('upsertUser:', e.message);
    return null;
  }
}

function getActiveMarriage(telegramId) {
  return db.prepare(`
    SELECT m.*,
      u1.first_name AS user1_first_name, u1.username AS user1_username,
      u2.first_name AS user2_first_name, u2.username AS user2_username
    FROM marriages m
    JOIN users u1 ON u1.telegram_id = m.user1_telegram_id
    JOIN users u2 ON u2.telegram_id = m.user2_telegram_id
    WHERE (m.user1_telegram_id = ? OR m.user2_telegram_id = ?)
      AND m.status != 'divorced'
    ORDER BY m.created_at DESC
    LIMIT 1
  `).get(telegramId, telegramId);
}

function getMarriageDays(marriage) {
  const created = new Date(marriage.created_at);
  return Math.max(0, Math.floor((Date.now() - created.getTime()) / 86400000));
}

function getLevelInfo(days) {
  const LEVELS = [
    { level: 1, name: 'Новая пара',             emoji: '💙', minDays: 0,   maxDays: 30,  color: '#007AFF', childBonus: 0 },
    { level: 2, name: 'Бронзовая свадьба',       emoji: '🥉', minDays: 30,  maxDays: 90,  color: '#CD7F32', childBonus: 5 },
    { level: 3, name: 'Серебряная свадьба',      emoji: '🥈', minDays: 90,  maxDays: 180, color: '#8E8E93', childBonus: 10 },
    { level: 4, name: 'Золотая свадьба',         emoji: '🥇', minDays: 180, maxDays: 365, color: '#FFD700', childBonus: 10 },
    { level: 5, name: 'Бриллиантовая свадьба',   emoji: '💎', minDays: 365, maxDays: 730, color: '#5AC8FA', childBonus: 20 },
    { level: 6, name: 'Легендарный союз',        emoji: '👑', minDays: 730, maxDays: null,color: '#FF9500', childBonus: 30 }
  ];
  let cur = LEVELS[0];
  for (const l of LEVELS) { if (days >= l.minDays) cur = l; }
  const idx  = LEVELS.indexOf(cur);
  const next = idx < LEVELS.length - 1 ? LEVELS[idx + 1] : null;
  let progress = 100, daysToNext = 0;
  if (next) {
    const span = next.minDays - cur.minDays;
    progress   = Math.min(99, Math.round(((days - cur.minDays) / span) * 100));
    daysToNext = next.minDays - days;
  }
  return { ...cur, next, progress, daysToNext };
}

function getMarriageStats(marriageId, telegramId) {
  try {
    const marriage = db.prepare('SELECT * FROM marriages WHERE id = ?').get(marriageId);
    if (!marriage) return null;

    const partnerId = marriage.user1_telegram_id === telegramId
      ? marriage.user2_telegram_id : marriage.user1_telegram_id;

    const today = new Date().toISOString().split('T')[0];

    const totalMsgs = db.prepare(
      'SELECT COALESCE(SUM(message_count),0) AS t FROM activity_logs WHERE marriage_id=?'
    ).get(marriageId).t;

    const todayMsgs = db.prepare(
      'SELECT COALESCE(SUM(message_count),0) AS t FROM activity_logs WHERE marriage_id=? AND log_date=?'
    ).get(marriageId, today).t;

    const weekMsgs = db.prepare(`
      SELECT COALESCE(SUM(message_count),0) AS t FROM activity_logs
      WHERE marriage_id=? AND log_date>=date('now','-7 days')
    `).get(marriageId).t;

    const activeDates = db.prepare(
      "SELECT DISTINCT log_date FROM activity_logs WHERE marriage_id=? AND message_count>0 ORDER BY log_date DESC"
    ).all(marriageId).map(r => r.log_date);

    // Серия дней
    let streak = 0;
    for (let i = 0; i < activeDates.length; i++) {
      const expected = new Date(Date.now() - i * 86400000).toISOString().split('T')[0];
      if (activeDates[i] === expected) streak++;
      else if (streak === 0 && i === 1) continue;
      else break;
    }

    const partnerLastLog = db.prepare(
      'SELECT MAX(log_date) AS last FROM activity_logs WHERE telegram_id=? AND marriage_id=?'
    ).get(partnerId, marriageId);

    let partnerInactiveDays = 0;
    if (partnerLastLog?.last) {
      partnerInactiveDays = Math.floor((Date.now() - new Date(partnerLastLog.last).getTime()) / 86400000);
    } else {
      const partnerUser = db.prepare('SELECT last_active FROM users WHERE telegram_id=?').get(partnerId);
      if (partnerUser?.last_active) {
        partnerInactiveDays = Math.floor((Date.now() - new Date(partnerUser.last_active).getTime()) / 86400000);
      } else {
        partnerInactiveDays = 999;
      }
    }

    const avgPerDay = activeDates.length > 0 ? Math.round(totalMsgs / activeDates.length) : 0;

    let loveLevel = 100;
    if      (partnerInactiveDays >= 7) loveLevel = 15;
    else if (partnerInactiveDays >= 5) loveLevel = 45;
    else if (partnerInactiveDays >= 3) loveLevel = 65;
    else if (partnerInactiveDays >= 1) loveLevel = 85;
    if (streak >= 30)    loveLevel = Math.min(100, loveLevel + 10);
    if (totalMsgs > 10000) loveLevel = Math.min(100, loveLevel + 5);

    return {
      totalMessages: totalMsgs,
      todayMessages: todayMsgs,
      weekMessages:  weekMsgs,
      streak,
      avgPerDay,
      activeDaysCount: activeDates.length,
      partnerInactiveDays,
      loveLevel: Math.max(0, Math.min(100, loveLevel))
    };
  } catch(e) {
    console.error('getMarriageStats:', e.message);
    return null;
  }
}

function logMessage(telegramId, marriageId) {
  const today = new Date().toISOString().split('T')[0];
  try {
    db.prepare(`
      INSERT INTO activity_logs (telegram_id, marriage_id, log_date, message_count)
      VALUES (?,?,?,1)
      ON CONFLICT(telegram_id, marriage_id, log_date)
      DO UPDATE SET message_count = message_count + 1
    `).run(telegramId, marriageId, today);
    db.prepare('UPDATE users SET last_active=CURRENT_TIMESTAMP WHERE telegram_id=?').run(telegramId);
  } catch(e) {
    console.error('logMessage:', e.message);
  }
}

function calcPregnancyChance(days, stats) {
  if (!stats || days < 180 || stats.loveLevel < 50) return 0;
  let chance = 10;
  chance += Math.floor(stats.totalMessages / 1000);
  if (stats.streak >= 30) chance += 5;
  if (days >= 180)        chance += 10;
  if (days >= 365)        chance += 20;
  return Math.min(90, Math.max(0, chance));
}

function makeBar(value, max = 100, len = 10) {
  const n = Math.round((Math.min(value, max) / max) * len);
  return '█'.repeat(Math.max(0, Math.min(n, len))) + '░'.repeat(Math.max(0, len - Math.min(n, len)));
}

// ══════════════════════════════════════════
// EXPRESS — WEB SERVER + API
// ══════════════════════════════════════════
const app = express();
app.use(express.json());
app.use(express.static(path.join(__dirname, 'public')));

app.get('/health', (_req, res) => res.json({ ok: true, ts: Date.now() }));

// GET /api/user/:telegramId  — все данные пары
app.get('/api/user/:telegramId', (req, res) => {
  try {
    const telegramId = parseInt(req.params.telegramId);
    if (!telegramId || isNaN(telegramId)) return res.status(400).json({ error: 'Invalid ID' });

    const user     = db.prepare('SELECT * FROM users WHERE telegram_id=?').get(telegramId);
    const marriage = getActiveMarriage(telegramId);

    if (!marriage) return res.json({ user: user || { telegram_id: telegramId, first_name: 'User' }, marriage: null });

    const days     = getMarriageDays(marriage);
    const level    = getLevelInfo(days);
    const stats    = getMarriageStats(marriage.id, telegramId);
    const pregChance = calcPregnancyChance(days, stats);
    const isUser1  = marriage.user1_telegram_id === telegramId;

    const pregnancy = db.prepare(
      "SELECT * FROM pregnancies WHERE marriage_id=? AND status='ongoing' LIMIT 1"
    ).get(marriage.id);

    const children = db.prepare(
      'SELECT * FROM children WHERE marriage_id=? ORDER BY born_at ASC'
    ).all(marriage.id);

    const weeklyData = db.prepare(`
      SELECT log_date, SUM(message_count) AS total
      FROM activity_logs
      WHERE marriage_id=? AND log_date>=date('now','-7 days')
      GROUP BY log_date ORDER BY log_date ASC
    `).all(marriage.id);

    const monthlyData = db.prepare(`
      SELECT log_date, SUM(message_count) AS total
      FROM activity_logs
      WHERE marriage_id=? AND log_date>=date('now','-30 days')
      GROUP BY log_date ORDER BY log_date ASC
    `).all(marriage.id);

    const byUser = db.prepare(`
      SELECT a.telegram_id, u.first_name, u.username, SUM(a.message_count) AS total
      FROM activity_logs a JOIN users u ON u.telegram_id=a.telegram_id
      WHERE a.marriage_id=? GROUP BY a.telegram_id
    `).all(marriage.id);

    let divorceRisk = null;
    if (stats && stats.partnerInactiveDays >= 3) {
      divorceRisk = {
        inactiveDays: stats.partnerInactiveDays,
        progress: Math.min(100, Math.round((stats.partnerInactiveDays / 7) * 100)),
        stage: stats.partnerInactiveDays >= 7 ? 'critical' : stats.partnerInactiveDays >= 5 ? 'high' : 'medium'
      };
    }

    let pregnancyData = null;
    if (pregnancy) {
      const pregDays = Math.floor((Date.now() - new Date(pregnancy.started_at).getTime()) / 86400000);
      pregnancyData = { ...pregnancy, daysElapsed: pregDays, daysTotal: 30, progress: Math.min(100, Math.round((pregDays / 30) * 100)) };
    }

    res.json({
      user,
      marriage: {
        id:             marriage.id,
        status:         marriage.status,
        createdAt:      marriage.created_at,
        days,
        level,
        stats,
        pregnancyChance: pregChance,
        pregnancy:      pregnancyData,
        children,
        partner: {
          telegramId: isUser1 ? marriage.user2_telegram_id : marriage.user1_telegram_id,
          firstName:  isUser1 ? marriage.user2_first_name  : marriage.user1_first_name,
          username:   isUser1 ? marriage.user2_username    : marriage.user1_username
        },
        weeklyData,
        monthlyData,
        byUser,
        divorceRisk
      }
    });
  } catch(err) {
    console.error('/api/user error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

// GET /api/levels  — все уровни
app.get('/api/levels', (_req, res) => {
  res.json([
    { level:1, name:'Новая пара',            emoji:'💙', daysRange:'0–30',    minDays:0,   color:'#007AFF', bonus:'Начало совместного пути',      childBonus:0  },
    { level:2, name:'Бронзовая свадьба',     emoji:'🥉', daysRange:'30–90',   minDays:30,  color:'#CD7F32', bonus:'Первый месяц позади!',         childBonus:5  },
    { level:3, name:'Серебряная свадьба',    emoji:'🥈', daysRange:'90–180',  minDays:90,  color:'#8E8E93', bonus:'+10% шанс на ребёнка',         childBonus:10 },
    { level:4, name:'Золотая свадьба',       emoji:'🥇', daysRange:'180–365', minDays:180, color:'#FFD700', bonus:'Открыта система детей! +10%',  childBonus:10 },
    { level:5, name:'Бриллиантовая свадьба', emoji:'💎', daysRange:'365–730', minDays:365, color:'#5AC8FA', bonus:'+20% шанс на ребёнка',         childBonus:20 },
    { level:6, name:'Легендарный союз',      emoji:'👑', daysRange:'730+',    minDays:730, color:'#FF9500', bonus:'Максимальный статус!',         childBonus:30 }
  ]);
});

// POST /api/pregnancy/try  — попытка зачать ребёнка
app.post('/api/pregnancy/try', (req, res) => {
  try {
    const { telegramId } = req.body;
    if (!telegramId) return res.status(400).json({ error: 'telegramId required' });

    const marriage = getActiveMarriage(telegramId);
    if (!marriage) return res.json({ success: false, error: 'Нет активного брака' });

    const days   = getMarriageDays(marriage);
    const stats  = getMarriageStats(marriage.id, telegramId);
    const chance = calcPregnancyChance(days, stats);

    if (chance === 0) {
      const reason = days < 180
        ? `Нужно ещё ${180 - days} дней до Золотой свадьбы`
        : 'Недостаточно активности';
      return res.json({ success: false, error: reason, chance });
    }

    const existing = db.prepare("SELECT id FROM pregnancies WHERE marriage_id=? AND status='ongoing'").get(marriage.id);
    if (existing) return res.json({ success: false, error: 'Уже ожидаете пополнения', alreadyPregnant: true });

    const roll     = Math.random() * 100;
    const pregnant = roll <= chance;
    if (pregnant) db.prepare("INSERT INTO pregnancies (marriage_id) VALUES (?)").run(marriage.id);

    res.json({ success: true, pregnant, chance, roll: Math.round(roll) });
  } catch(err) {
    res.status(500).json({ error: err.message });
  }
});

// POST /api/log-activity  — логировать активность вручную из Mini App
app.post('/api/log-activity', (req, res) => {
  try {
    const { telegramId } = req.body;
    if (!telegramId) return res.status(400).json({ error: 'telegramId required' });
    const marriage = getActiveMarriage(telegramId);
    if (marriage) logMessage(telegramId, marriage.id);
    res.json({ ok: true });
  } catch(err) {
    res.status(500).json({ error: err.message });
  }
});

app.listen(PORT, '0.0.0.0', () => {
  console.log(`🌐 Web server on port ${PORT}`);
  console.log(`📱 Mini App: ${WEBAPP_URL}`);
});

// ══════════════════════════════════════════
// TELEGRAM BOT
// ══════════════════════════════════════════
const bot = new Telegraf(BOT_TOKEN);

// ── Middleware: регистрация + трекинг активности ──
bot.use(async (ctx, next) => {
  if (!ctx.from) return next();
  try { upsertUser(ctx.from); } catch(e) {}

  if (ctx.message?.text && !ctx.message.text.startsWith('/')) {
    try {
      const marriage = getActiveMarriage(ctx.from.id);
      if (marriage) {
        logMessage(ctx.from.id, marriage.id);
        await sendInactivityWarnings(ctx, marriage);
      }
    } catch(e) { console.error('Middleware activity error:', e.message); }
  }
  return next();
});

async function sendInactivityWarnings(ctx, marriage) {
  const stats     = getMarriageStats(marriage.id, ctx.from.id);
  if (!stats) return;
  const partnerId = marriage.user1_telegram_id === ctx.from.id
    ? marriage.user2_telegram_id : marriage.user1_telegram_id;

  if (stats.partnerInactiveDays >= 7 && marriage.status === 'active') {
    db.prepare("UPDATE marriages SET status='divorce_risk' WHERE id=?").run(marriage.id);
  }

  for (const days of [3, 5, 7]) {
    if (stats.partnerInactiveDays !== days) continue;
    const wtype = `warn_${days}d`;
    const sent  = db.prepare(`
      SELECT id FROM notifications
      WHERE telegram_id=? AND marriage_id=? AND type=? AND sent_at>datetime('now','-23 hours')
    `).get(partnerId, marriage.id, wtype);
    if (sent) continue;
    const msgs = {
      warn_3d: `⚠️ *Внимание!*\n\nВаши отношения требуют внимания.\nПартнёр не видит вас уже *3 дня*.\n\nНапишите им прямо сейчас! 💙`,
      warn_5d: `🔴 *Отношения ослабевают!*\n\nПартнёр не активен уже *5 дней*.\nУровень любви снижается.\n\nСрочно напишите партнёру! 💔`,
      warn_7d: `🚨 *Критическая ситуация!*\n\nПартнёр не отвечает *7 дней*.\nОтношения под угрозой разрыва!\n\nЧтобы сохранить брак — напишите партнёру! 💔`
    };
    try {
      await bot.telegram.sendMessage(partnerId, msgs[wtype], { parse_mode: 'Markdown' });
      db.prepare('INSERT INTO notifications (telegram_id,marriage_id,type) VALUES (?,?,?)').run(partnerId, marriage.id, wtype);
    } catch(e) {}
  }
}

// ── /start ──
bot.start(async (ctx) => {
  upsertUser(ctx.from);
  const marriage = getActiveMarriage(ctx.from.id);
  const webUrl   = `${WEBAPP_URL}?user_id=${ctx.from.id}`;

  const btns = [[Markup.button.webApp('💍 Открыть Verifure', webUrl)]];

  if (marriage) {
    const days  = getMarriageDays(marriage);
    const level = getLevelInfo(days);
    const pName = marriage.user1_telegram_id === ctx.from.id ? marriage.user2_first_name : marriage.user1_first_name;
    btns.push([Markup.button.callback(`${level.emoji} Статус пары`, 'quick_status'), Markup.button.callback('👨‍👩‍👦 Семья', 'quick_family')]);
    btns.push([Markup.button.callback('💔 Развод', 'quick_divorce'), Markup.button.callback('ℹ️ Помощь', 'help')]);

    await ctx.replyWithMarkdown(
      `💍 *Verifure — Отношения*\n\nПривет, *${ctx.from.first_name}*! 👋\n\n${level.emoji} *${level.name}*\n👫 Вы и *${pName}* — *${days} дней* вместе`,
      Markup.inlineKeyboard(btns)
    );
  } else {
    btns.push([Markup.button.callback('💍 Как создать пару', 'help_marry')]);
    btns.push([Markup.button.callback('ℹ️ Помощь', 'help')]);

    await ctx.replyWithMarkdown(
      `💍 *Verifure — Медвежьи отношения*\n\nПривет, *${ctx.from.first_name}*! 👋\n\nСистема отслеживания отношений для Telegram.\n\n👫 Чтобы создать пару:\n\`/marry @username\`\n\n_Оба партнёра должны написать боту_ /start`,
      Markup.inlineKeyboard(btns)
    );
  }
});

// ── /marry @username ──
bot.command('marry', async (ctx) => {
  const parts  = ctx.message.text.trim().split(/\s+/);
  const rawArg = parts[1] || '';

  if (!rawArg) {
    return ctx.replyWithMarkdown(
      '💍 *Предложение брака*\n\nИспользование:\n`/marry @username`\n\n_Партнёр должен сначала написать боту /start_',
      Markup.inlineKeyboard([[Markup.button.callback('❌ Закрыть', 'close')]])
    );
  }

  const targetUsername = rawArg.replace('@', '').toLowerCase().trim();

  if (targetUsername === (ctx.from.username || '').toLowerCase()) {
    return ctx.reply('❌ Нельзя создать пару с самим собой!');
  }

  const myMarriage = getActiveMarriage(ctx.from.id);
  if (myMarriage) {
    return ctx.replyWithMarkdown('❌ Вы уже в браке!\n\n`/divorce` — развод\n`/status` — статус пары',
      Markup.inlineKeyboard([[Markup.button.callback('❌ Закрыть', 'close')]]));
  }

  const targetUser = db.prepare('SELECT * FROM users WHERE LOWER(username)=?').get(targetUsername);
  if (!targetUser) {
    return ctx.replyWithMarkdown(`❌ Пользователь @${targetUsername} не зарегистрирован.\n\n_Попросите написать боту /start_`);
  }

  if (getActiveMarriage(targetUser.telegram_id)) {
    return ctx.replyWithMarkdown(`❌ @${targetUsername} уже состоит в браке.`);
  }

  const pending = db.prepare(`
    SELECT id FROM proposals
    WHERE from_telegram_id=? AND to_telegram_id=? AND status='pending'
    AND created_at>datetime('now','-24 hours')
  `).get(ctx.from.id, targetUser.telegram_id);

  if (pending) return ctx.reply('⏳ Вы уже отправили предложение! Ожидайте ответа.');

  const result     = db.prepare('INSERT INTO proposals (from_telegram_id,to_telegram_id,to_username) VALUES (?,?,?)').run(ctx.from.id, targetUser.telegram_id, targetUsername);
  const proposalId = result.lastInsertRowid;
  const fromDisplay = ctx.from.username ? `@${ctx.from.username}` : ctx.from.first_name;

  try {
    await bot.telegram.sendMessage(targetUser.telegram_id,
      `💍 *Предложение руки и сердца!*\n\n${fromDisplay} предлагает вам создать пару!\n\nПримите или отклоните:`,
      {
        parse_mode: 'Markdown',
        reply_markup: { inline_keyboard: [[
          { text: '✅ Принять', callback_data: `accept_${proposalId}` },
          { text: '❌ Отклонить', callback_data: `reject_${proposalId}` }
        ]]}
      }
    );
    await ctx.replyWithMarkdown(`💍 Предложение отправлено @${targetUsername}!\n\nОжидайте ответа... 💙`);
  } catch(e) {
    db.prepare("UPDATE proposals SET status='expired' WHERE id=?").run(proposalId);
    await ctx.replyWithMarkdown(`❌ Не удалось доставить сообщение @${targetUsername}.\n\n_Пользователь должен написать /start боту_`);
  }
});

// ── Принятие предложения ──
bot.action(/^accept_(\d+)$/, async (ctx) => {
  await ctx.answerCbQuery('💍 Обработка...');
  const proposalId = parseInt(ctx.match[1]);
  const proposal   = db.prepare('SELECT * FROM proposals WHERE id=?').get(proposalId);

  if (!proposal || proposal.status !== 'pending') return ctx.editMessageText('❌ Предложение устарело.');
  if (proposal.to_telegram_id !== ctx.from.id) return ctx.answerCbQuery('❌ Это не ваше предложение.', { show_alert: true });
  if (getActiveMarriage(proposal.from_telegram_id) || getActiveMarriage(proposal.to_telegram_id)) {
    db.prepare("UPDATE proposals SET status='expired' WHERE id=?").run(proposalId);
    return ctx.editMessageText('❌ Один из партнёров уже в браке.');
  }

  db.prepare('INSERT INTO marriages (user1_telegram_id,user2_telegram_id) VALUES (?,?)').run(proposal.from_telegram_id, proposal.to_telegram_id);
  db.prepare("UPDATE proposals SET status='accepted' WHERE id=?").run(proposalId);

  const fromUser   = db.prepare('SELECT * FROM users WHERE telegram_id=?').get(proposal.from_telegram_id);
  const fromDisp   = fromUser?.username ? `@${fromUser.username}` : (fromUser?.first_name || 'Партнёр');
  const toDisp     = ctx.from.username ? `@${ctx.from.username}` : ctx.from.first_name;
  const dateStr    = new Date().toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
  const myWebApp   = `${WEBAPP_URL}?user_id=${ctx.from.id}`;

  await ctx.editMessageText(
    `💍 *Поздравляем!*\n\nВы и ${fromDisp} теперь официально вместе!\n📅 ${dateStr} 🎉`,
    { parse_mode: 'Markdown', reply_markup: { inline_keyboard: [[{ text: '💍 Открыть Verifure', web_app: { url: myWebApp } }]] } }
  );

  try {
    await bot.telegram.sendMessage(proposal.from_telegram_id,
      `💍 *Поздравляем!*\n\n${toDisp} принял(а) ваше предложение!\nВы теперь вместе — ${dateStr} 🎉`,
      { parse_mode: 'Markdown', reply_markup: { inline_keyboard: [[{ text: '💍 Открыть Verifure', web_app: { url: `${WEBAPP_URL}?user_id=${proposal.from_telegram_id}` } }]] } }
    );
  } catch(e) {}
});

// ── Отклонение предложения ──
bot.action(/^reject_(\d+)$/, async (ctx) => {
  await ctx.answerCbQuery();
  const proposalId = parseInt(ctx.match[1]);
  const proposal   = db.prepare('SELECT * FROM proposals WHERE id=?').get(proposalId);
  if (!proposal) return ctx.editMessageText('❌ Предложение не найдено.');
  if (proposal.to_telegram_id !== ctx.from.id) return ctx.answerCbQuery('❌ Не ваше предложение.', { show_alert: true });

  db.prepare("UPDATE proposals SET status='rejected' WHERE id=?").run(proposalId);
  const toDisp = ctx.from.username ? `@${ctx.from.username}` : ctx.from.first_name;
  await ctx.editMessageText('❌ Вы отклонили предложение.');
  try { await bot.telegram.sendMessage(proposal.from_telegram_id, `💔 ${toDisp} отклонил(а) ваше предложение.`); } catch(e) {}
});

// ── /divorce ──
bot.command('divorce', async (ctx) => {
  const marriage = getActiveMarriage(ctx.from.id);
  if (!marriage) return ctx.reply('❌ Вы не состоите в браке.');
  const days  = getMarriageDays(marriage);
  const level = getLevelInfo(days);
  const pName = marriage.user1_telegram_id === ctx.from.id ? marriage.user2_first_name : marriage.user1_first_name;

  await ctx.replyWithMarkdown(
    `⚠️ *Подача на развод*\n\nБрак с *${pName}*\n${level.emoji} ${level.name} — *${days} дней*\n\n_Это действие нельзя отменить!_`,
    Markup.inlineKeyboard([[
      Markup.button.callback('✅ Да, развод', `do_divorce_${marriage.id}`),
      Markup.button.callback('❌ Отмена', 'close')
    ]])
  );
});

bot.action(/^do_divorce_(\d+)$/, async (ctx) => {
  await ctx.answerCbQuery();
  const marriageId = parseInt(ctx.match[1]);
  const marriage   = db.prepare('SELECT * FROM marriages WHERE id=?').get(marriageId);
  if (!marriage) return ctx.editMessageText('❌ Брак не найден.');
  if (marriage.user1_telegram_id !== ctx.from.id && marriage.user2_telegram_id !== ctx.from.id)
    return ctx.answerCbQuery('❌ Это не ваш брак.', { show_alert: true });

  db.prepare(`UPDATE marriages SET status='divorced', divorce_started_at=CURRENT_TIMESTAMP, divorce_initiator=? WHERE id=?`).run(ctx.from.id, marriageId);
  db.prepare("UPDATE pregnancies SET status='failed' WHERE marriage_id=? AND status='ongoing'").run(marriageId);

  const partnerId = marriage.user1_telegram_id === ctx.from.id ? marriage.user2_telegram_id : marriage.user1_telegram_id;
  const userDisp  = ctx.from.username ? `@${ctx.from.username}` : ctx.from.first_name;

  await ctx.editMessageText('💔 Развод оформлен. История брака сохранена.');
  try { await bot.telegram.sendMessage(partnerId, `💔 *${userDisp}* подал(а) на развод.\nВаш брак был расторгнут.`, { parse_mode: 'Markdown' }); } catch(e) {}
});

// ── /status ──
bot.command('status', async (ctx) => {
  upsertUser(ctx.from);
  const marriage = getActiveMarriage(ctx.from.id);
  if (!marriage) {
    return ctx.replyWithMarkdown('💔 *Вы не в браке*\n\n`/marry @username` — создать пару',
      Markup.inlineKeyboard([[Markup.button.callback('💍 Как создать пару?', 'help_marry')]]));
  }
  const days    = getMarriageDays(marriage);
  const level   = getLevelInfo(days);
  const stats   = getMarriageStats(marriage.id, ctx.from.id);
  const isU1    = marriage.user1_telegram_id === ctx.from.id;
  const pName   = isU1 ? marriage.user2_first_name : marriage.user1_first_name;

  let text = `${level.emoji} *${level.name}*\n\n`;
  text += `👫 *${ctx.from.first_name} ❤️ ${pName}*\n`;
  text += `📅 В браке: *${days} дней*\n`;
  if (stats) {
    text += `❤️ Уровень любви: ${makeBar(stats.loveLevel)} *${stats.loveLevel}%*\n\n`;
    text += `💬 Сообщений: *${stats.totalMessages.toLocaleString('ru')}*\n`;
    text += `🔥 Серия: *${stats.streak} дней*\n`;
    text += `📈 В среднем: *${stats.avgPerDay}/день*\n`;
    text += `📅 Сегодня: *${stats.todayMessages} сообщений*\n\n`;
    if (stats.partnerInactiveDays >= 3) text += `⚠️ *Партнёр не активен ${stats.partnerInactiveDays} дней!*\n\n`;
  }
  if (level.next) {
    text += `⏭️ ${makeBar(level.progress)} *${level.progress}%*\n`;
    text += `До ${level.next.emoji} ${level.next.name}: *${level.daysToNext} дней*`;
  } else {
    text += `✨ *Максимальный уровень!*`;
  }

  await ctx.replyWithMarkdown(text, Markup.inlineKeyboard([
    [Markup.button.webApp('📱 Открыть приложение', `${WEBAPP_URL}?user_id=${ctx.from.id}`)],
    [Markup.button.callback('🔄 Обновить', 'quick_status'), Markup.button.callback('👨‍👩‍👦 Семья', 'quick_family')]
  ]));
});

// ── /family ──
bot.command('family', async (ctx) => {
  const marriage = getActiveMarriage(ctx.from.id);
  if (!marriage) return ctx.reply('❌ Вы не состоите в браке.');
  const days       = getMarriageDays(marriage);
  const stats      = getMarriageStats(marriage.id, ctx.from.id);
  const chance     = calcPregnancyChance(days, stats);
  const pregnancy  = db.prepare("SELECT * FROM pregnancies WHERE marriage_id=? AND status='ongoing'").get(marriage.id);
  const childCount = db.prepare('SELECT COUNT(*) AS c FROM children WHERE marriage_id=?').get(marriage.id).c;

  let text = `👨‍👩‍👦 *Семья*\n\n👶 Количество детей: *${childCount}*\n\n`;
  if (pregnancy) {
    const pregDays = Math.floor((Date.now() - new Date(pregnancy.started_at).getTime()) / 86400000);
    const pct      = Math.min(100, Math.round(pregDays / 30 * 100));
    text += `🤰 *Ожидание пополнения!*\nДень: *${pregDays}/30*\n${makeBar(pct)} *${pct}%*\n\n`;
  }
  if (days < 180) {
    text += `⏳ До возможности иметь детей: *${180 - days} дней*\n_(нужна 🥇 Золотая свадьба)_`;
  } else {
    text += `🎲 Шанс пополнения: *${chance}%*`;
    if (!pregnancy && chance > 0) text += `\n✨ Ежедневный розыгрыш активен!`;
  }

  await ctx.replyWithMarkdown(text, Markup.inlineKeyboard([
    [Markup.button.webApp('📱 Открыть Verifure', `${WEBAPP_URL}?user_id=${ctx.from.id}`)]
  ]));
});

// ── /help ──
bot.command('help', async (ctx) => {
  await ctx.replyWithMarkdown(`
💍 *Verifure — Помощь*

*Команды:*
/start — Главное меню
/marry @username — Предложить брак
/divorce — Развестись
/status — Статус пары
/family — Информация о семье
/help — Эта справка

*Уровни брака:*
💙 0–30 дней — Новая пара
🥉 30–90 — Бронзовая свадьба
🥈 90–180 — Серебряная свадьба
🥇 180–365 — Золотая свадьба _(+ дети!)_
💎 365–730 — Бриллиантовая свадьба
👑 730+ — Легендарный союз

*Система детей:*
• Доступна после 180 дней брака
• Шанс растёт с уровнем и активностью
• Беременность длится 30 дней
• При рождении — подарок от @Verifure

*Активность:*
Пишите боту или в группах с ботом
Молчание 7 дней = риск развода!
  `.trim(), Markup.inlineKeyboard([
    [Markup.button.webApp('📱 Открыть приложение', `${WEBAPP_URL}?user_id=${ctx.from.id}`)]
  ]));
});

// ── Callback Actions ──
