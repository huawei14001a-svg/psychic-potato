  try { await ctx.deleteMessage(); } catch(e) {}
});

// ── Фоновые задачи (каждый час) ──
async function backgroundTasks() {
  try {
    // Проверка завершённых беременностей
    const readyPregs = db.prepare(`
      SELECT p.*, m.user1_telegram_id AS uid1, m.user2_telegram_id AS uid2
      FROM pregnancies p JOIN marriages m ON m.id=p.marriage_id
      WHERE p.status='ongoing' AND p.started_at<=datetime('now','-30 days')
    `).all();

    for (const preg of readyPregs) {
      db.prepare("UPDATE pregnancies SET status='born',born_at=CURRENT_TIMESTAMP WHERE id=?").run(preg.id);
      const bn = db.prepare('SELECT COUNT(*) AS c FROM children WHERE marriage_id=?').get(preg.marriage_id).c + 1;
      db.prepare('INSERT INTO children (marriage_id,birth_number) VALUES (?,?)').run(preg.marriage_id, bn);
      for (const uid of [preg.uid1, preg.uid2]) {
        try {
          await bot.telegram.sendMessage(uid,
            `🎉 *В вашей семье появился малыш!*\n\nПоздравляем с рождением ребёнка! 👶\n\nПодарок будет отправлен через @Verifure 🎁`,
            { parse_mode: 'Markdown' }
          );
        } catch(e) {}
      }
    }

    // Ежедневный розыгрыш беременности
    const eligible = db.prepare(`
      SELECT m.id, m.user1_telegram_id AS uid1, m.user2_telegram_id AS uid2, m.created_at
      FROM marriages m
      WHERE m.status='active' AND m.created_at<=datetime('now','-180 days')
        AND m.id NOT IN (SELECT marriage_id FROM pregnancies WHERE status='ongoing')
    `).all();

    for (const mar of eligible) {
      const days   = Math.floor((Date.now() - new Date(mar.created_at).getTime()) / 86400000);
      const stats  = getMarriageStats(mar.id, mar.uid1);
      const chance = calcPregnancyChance(days, stats);
      if (chance > 0 && Math.random() * 100 <= chance) {
        db.prepare('INSERT INTO pregnancies (marriage_id) VALUES (?)').run(mar.id);
        for (const uid of [mar.uid1, mar.uid2]) {
          try {
            await bot.telegram.sendMessage(uid,
              `🌟 *Отличные новости!*\n\nВаша пара ожидает пополнения семьи! 🤰\n\n_Малыш появится через 30 дней_`,
              { parse_mode: 'Markdown' }
            );
          } catch(e) {}
        }
      }
    }
  } catch(e) {
    console.error('backgroundTasks error:', e);
  }
}

setInterval(backgroundTasks, 60 * 60 * 1000);
setTimeout(backgroundTasks, 5000);

// ── Запуск бота ──
bot.launch({ allowedUpdates: ['message', 'callback_query'] })
  .then(() => console.log(`🤖 Verifure Bot запущен! @${bot.botInfo?.username}`))
  .catch(err => { console.error('❌ Ошибка запуска:', err.message); process.exit(1); });

process.once('SIGINT',  () => { bot.stop('SIGINT');  db.close(); });
process.once('SIGTERM', () => { bot.stop('SIGTERM'); db.close(); });
