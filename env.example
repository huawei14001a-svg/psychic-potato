  const marriage = getActiveMarriage(ctx.from.id);
  if (!marriage) return ctx.reply('💔 Вы не в браке. /marry @username');
  const days  = getMarriageDays(marriage);
  const level = getLevelInfo(days);
  const stats = getMarriageStats(marriage.id, ctx.from.id);
  const pName = marriage.user1_telegram_id === ctx.from.id ? marriage.user2_first_name : marriage.user1_first_name;

  await ctx.reply(
    `${level.emoji} ${level.name}\n👫 ${ctx.from.first_name} ❤️ ${pName}\n📅 ${days} дней\n❤️ ${makeBar(stats?.loveLevel || 100)} ${stats?.loveLevel || 100}%\n💬 ${(stats?.totalMessages || 0).toLocaleString('ru')} сообщений\n🔥 Серия: ${stats?.streak || 0} дней`,
    { reply_markup: { inline_keyboard: [[{ text: '📱 Подробнее', web_app: { url: `${WEBAPP_URL}?user_id=${ctx.from.id}` } }]] } }
  );
});

bot.action('quick_family', async (ctx) => {
  await ctx.answerCbQuery();
  const marriage = getActiveMarriage(ctx.from.id);
  if (!marriage) return ctx.reply('❌ Нет активного брака');
